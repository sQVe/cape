{
  "name": "cape",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @cape/cli build",
    "check": "vp check",
    "fallow": "fallow",
    "fallow:audit": "fallow audit --ci",
    "fallow:fix": "fallow fix --dry-run",
    "fallow:staged": "fallow audit --changed-since HEAD --format compact",
    "typecheck": "tsc -p cli/tsconfig.json",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "prepare": "vp config",
    "test": "vp test",
    "test:unit": "vp test --project unit",
    "test:e2e": "vp test --project e2e"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "fallow": "2.101.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.69.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite-plus": "0.1.24"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
