{
  "scripts": {
    "format": "prettier --write --ignore-unknown .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "lint-staged": "^15.5.1",
    "simple-git-hooks": "^2.12.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged && bash scripts/beads-sync.sh"
  },
  "lint-staged": {
    "*.md": "prettier --write --ignore-unknown"
  }
}
