{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cape hook session-start"
          }
        ]
      },
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cape hook session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cape hook user-prompt-submit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cape hook pre-tool-use --matcher Bash"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "cape hook pre-tool-use --matcher Skill"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_linear_linear__save_issue",
        "hooks": [
          {
            "type": "command",
            "command": "cape hook post-tool-use --matcher linear-write"
          }
        ]
      }
    ]
  }
}
